BACKEND_PORT=4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: required only for admin-level backend operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email campaign provider (choose one: resend | sendgrid | mailgun)
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@your-domain.com

# Resend
RESEND_API_KEY=your-resend-api-key

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.your-domain.com
MAILGUN_BASE_URL=https://api.mailgun.net/v3

# Optional campaign protections
EMAIL_BLOCKED_DOMAINS=tempmail.com,mailinator.com
EMAIL_CAMPAIGN_MAX_RECIPIENTS=5000
EMAIL_CAMPAIGN_MAX_CREATE_PER_HOUR=20
EMAIL_CAMPAIGN_MAX_QUEUE_PER_HOUR=20
EMAIL_CAMPAIGN_MAX_SEND_PER_HOUR=8
EMAIL_CAMPAIGN_MAX_SEND_PER_DAY=40
EMAIL_CAMPAIGN_MIN_SECONDS_BETWEEN_SENDS=20
EMAIL_SEND_BATCH_SIZE=500

# Support IA Cohere
COHERE_API_KEY=your-cohere-api-key
COHERE_MODEL=command-r-plus
SUPPORT_AI_DAILY_LIMIT=20
SUPPORT_AI_HISTORY_LIMIT=30
SUPPORT_AI_CONTEXT_TURNS=6
SUPPORT_AI_MAX_QUESTION_CHARS=1200
SUPPORT_AI_MAX_TOKENS=180

# PayDunya (paiements dons + carte membre)
# Laisser vide pour auto-selection selon PAYDUNYA_MODE.
PAYDUNYA_BASE_URL=
PAYDUNYA_TEST_BASE_URL=https://app.paydunya.com/sandbox-api/v1
PAYDUNYA_LIVE_BASE_URL=https://app.paydunya.com/api/v1
PAYDUNYA_MODE=test
# Option recommande: definir les 2 jeux de cles et laisser PAYDUNYA_MODE choisir.
PAYDUNYA_TEST_MASTER_KEY=your-paydunya-test-master-key
PAYDUNYA_TEST_PUBLIC_KEY=your-paydunya-test-public-key
PAYDUNYA_TEST_PRIVATE_KEY=your-paydunya-test-private-key
PAYDUNYA_TEST_TOKEN=your-paydunya-test-token
PAYDUNYA_LIVE_MASTER_KEY=your-paydunya-live-master-key
PAYDUNYA_LIVE_PUBLIC_KEY=your-paydunya-live-public-key
PAYDUNYA_LIVE_PRIVATE_KEY=your-paydunya-live-private-key
PAYDUNYA_LIVE_TOKEN=your-paydunya-live-token
# Compatibilite (fallback): cles sans suffixe.
PAYDUNYA_MASTER_KEY=your-paydunya-master-key
PAYDUNYA_PUBLIC_KEY=your-paydunya-public-key
PAYDUNYA_PRIVATE_KEY=your-paydunya-private-key
PAYDUNYA_TOKEN=your-paydunya-token
PAYDUNYA_STORE_NAME=CZI
PAYDUNYA_STORE_TAGLINE=Paiements CZI
PAYDUNYA_STORE_WEBSITE_URL=https://reseauczi.org/
PAYDUNYA_STORE_PHONE=+22800000000
FRONTEND_PUBLIC_URL=https://collectifzeroindigent.vercel.app
BACKEND_PUBLIC_URL=https://your-render-backend-url.onrender.com
PAYDUNYA_CALLBACK_URL=https://collectifzeroindigent.vercel.app/app/dons?payment=callback
PAYDUNYA_CANCEL_URL=https://collectifzeroindigent.vercel.app/app/dons?payment=cancelled
PAYDUNYA_IPN_URL=https://your-render-backend-url.onrender.com/api/payments/paydunya/ipn
